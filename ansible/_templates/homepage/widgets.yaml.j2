#jinja2: trim_blocks: True, lstrip_blocks: True
---
# Information widgets (header). All keyless: openmeteo needs no API key, and
# resources reports the host running Homepage
- search:
    provider: duckduckgo
    target: _blank
- datetime:
    text_size: xl
    format:
      timeStyle: short
      dateStyle: short
- openmeteo:
    label: Here
    latitude: 32.09
    longitude: 15.07
    units: metric
    cache: 5
- resources:
    label: pi5
    cpu: true
    memory: true
    disk: /