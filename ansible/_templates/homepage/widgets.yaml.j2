#jinja2: trim_blocks: True, lstrip_blocks: True
---
# Information widgets (header). All keyless: openmeteo needs no API key, and
# resources reports the host running Homepage (fed).
- search:
    provider: duckduckgo
    target: _blank
- datetime:
    text_size: xl
    format:
      timeStyle: short
      dateStyle: long
- openmeteo:
    label: Amsterdam
    latitude: 52.37
    longitude: 4.90
    units: metric
    cache: 5
- resources:
    label: fed
    cpu: true
    memory: true
    disk: /
