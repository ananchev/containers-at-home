# LibreChat .env — RENDERED by applications/librechat.yml (do not edit on the host;
# edit the template + re-run the playbook). Injected into the container via env_file.
# Secrets come from vault (librechat_secrets.*); see notes/librechat.md.

#==================== server ====================#
HOST=0.0.0.0
PORT=3080

# LAN-only: reached directly at the host IP:port, no reverse proxy in front.
# (No CF/NPM — the only inbound need is you, from the LAN.)
DOMAIN_CLIENT={{ librechat_base_url }}
DOMAIN_SERVER={{ librechat_base_url }}

#==================== datastores ====================#
# Container-name DNS on librechat-net (see the playbook's container names).
MONGO_URI=mongodb://librechat-mongodb:27017/LibreChat
MEILI_HOST=http://librechat-meilisearch:7700
MEILI_MASTER_KEY={{ librechat_secrets.meili_master_key }}
SEARCH=true

#==================== crypto / auth ====================#
CREDS_KEY={{ librechat_secrets.creds_key }}
CREDS_IV={{ librechat_secrets.creds_iv }}
JWT_SECRET={{ librechat_secrets.jwt_secret }}
JWT_REFRESH_SECRET={{ librechat_secrets.jwt_refresh_secret }}

# Session lifetime (millisecond expressions; LibreChat evaluates them).
# SESSION_EXPIRY = access-token (JWT) lifetime — kept long here so a LAN session
# survives inactivity WITHOUT relying on the refresh cookie (plain-http origins make
# the Secure refresh cookie finicky, which is what bounces you to login). Default 15m.
# REFRESH_TOKEN_EXPIRY = overall stay-logged-in window. Default 7d.
SESSION_EXPIRY={{ librechat_session_expiry }}
REFRESH_TOKEN_EXPIRY={{ librechat_refresh_expiry }}

# Built-in email/password auth. Registration is OPEN for the first run so you can
# create your account, then flip to false (re-run with -e librechat_allow_registration=false).
ALLOW_REGISTRATION={{ librechat_allow_registration | default(true) | lower }}
ALLOW_EMAIL_LOGIN=true
ALLOW_SOCIAL_LOGIN=false

#==================== config + endpoints ====================#
CONFIG_PATH=/app/librechat.yaml
# OpenRouter is wired as a `custom` endpoint in librechat.yaml; this is the key it
# references as ${OPENROUTER_API_KEY}. (Deliberately NOT named OPENROUTER_KEY, which
# triggers LibreChat's deprecated auto-endpoint instead of the custom one.)
OPENROUTER_API_KEY={{ librechat_secrets.openrouter_api_key }}
{% if librechat_enable_mcp | default(false) | bool %}

#==================== docs-bridge MCP (stage 2.2) ====================#
# Bearer for the docs-bridge /mcp call; reuses the existing docs-bridge secret.
# Referenced as ${DOCS_BRIDGE_TOKEN} in librechat.yaml mcpServers.
DOCS_BRIDGE_TOKEN={{ docs_bridge_secrets.bearer_token }}
{% endif %}
