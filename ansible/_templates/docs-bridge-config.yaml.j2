# Managed by Ansible (containers-at-home). Do not edit on the host.
# Rendered from the docs_bridge contract + per-host host_tuning in
# applications/docs-bridge.yml (design §6). Mounted at /config/config.yaml.
embedding_model: {{ docs_bridge.embedding_model }}
embedding_dim: {{ docs_bridge.embedding_dim }}
# Embed backend: onnx (ONNX/INT8, validated default — 4.5x faster, on-par quality)
# or flagembedding (torch fallback). int8 selects the baked model.int8.onnx.
embedding_backend: {{ docs_bridge.embedding_backend }}
embedding_int8: {{ docs_bridge.embedding_int8 | string | lower }}

chunk:
  target_tokens: {{ docs_bridge.chunk.target_tokens }}
  overlap: {{ docs_bridge.chunk.overlap }}
  strategy: {{ docs_bridge.chunk.strategy }}

parse:
  ocr: {{ docs_bridge.parse.ocr | string | lower }}
  table_structure: {{ docs_bridge.parse.table_structure | string | lower }}

qdrant:
  host: {{ docs_bridge.qdrant.host }}
  port: {{ docs_bridge.qdrant.port }}
  on_disk_vectors: {{ docs_bridge.qdrant.on_disk_vectors | string | lower }}
  quantization: {{ docs_bridge.qdrant.quantization }}

ingest:
  batch_size: {{ docs_bridge.ingest.batch_size }}
  two_pass: {{ docs_bridge.ingest.two_pass | string | lower }}

manifest_path: {{ docs_bridge.manifest_path }}

# docs-bridge server only (ignored by the ingest-worker).
rerank:
  enabled: {{ docs_bridge.rerank.enabled | string | lower }}
  model_dir: {{ docs_bridge.rerank.model_dir }}
  int8: {{ docs_bridge.rerank.int8 | string | lower }}
  max_length: {{ docs_bridge.rerank.max_length }}
  top_n: {{ docs_bridge.rerank.top_n }}

server:
  port: {{ docs_bridge.server.port }}
  default_k: {{ docs_bridge.server.default_k }}
  prefetch_limit: {{ docs_bridge.server.prefetch_limit }}
{% if docs_bridge.server.instructions is defined and docs_bridge.server.instructions | trim %}
  instructions: |
    {{ docs_bridge.server.instructions | trim | indent(4) }}
{% endif %}

subjects:
{% for s in docs_bridge.subjects %}
  - name: {{ s.name }}
    dir: {{ s.dir }}
    collection: {{ s.collection }}
{% if s.description is defined and s.description | trim %}
    description: {{ s.description | trim | tojson }}
{% endif %}
{% endfor %}
